WITH DataWithRowNumbers AS (
        SELECT 
            채널명,
            고객경험단계명, 
            서비스품질명,
            VOC원문내용,
            ROW_NUMBER() OVER (PARTITION BY 서비스품질명 ORDER BY RAND()) AS RowNum,
            COUNT(*) OVER (PARTITION BY 서비스품질명) AS TotalCount
        FROM inst1.TSCCVMGD3
        WHERE 
            채널명 = '{channel_name}' AND 
            조사년도 = {year} AND 
            반기구분명 = '{half}' AND 
            거래은행명 = 'KB국민은행' AND
            LENGTH(REPLACE(VOC원문내용, ' ', '')) BETWEEN 10 AND 200
    ),
    SampledData AS (
        SELECT 
            채널명,
            고객경험단계명, 
            서비스품질명,
            VOC원문내용,
            RowNum,
            TotalCount,
            {sample_size} AS SampleSize
        FROM DataWithRowNumbers
    ),
    FinalSample AS (
        SELECT 
            채널명,
            고객경험단계명, 
            서비스품질명,
            VOC원문내용
        FROM SampledData
        WHERE RowNum <= SampleSize
    )
    SELECT 
        고객경험단계명 AS 고객경험단계, 
        GROUP_CONCAT(VOC원문내용, '|') AS 원문 
    FROM FinalSample
    GROUP BY 채널명, 고객경험단계명